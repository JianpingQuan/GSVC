#!/usr/bin/env python

import pandas as pd

with open("metadata2.list") as f:
    files = [line.strip() for line in f]

dfs = [pd.read_csv(f, sep="\t") for f in files]
df = pd.concat(dfs, ignore_index=True)

df.to_csv("/public1/home/m6l600415/Public/dRep/all_virus_metadata2.tsv",
          sep="\t", index=False)

df[df["retained"] == 1].to_csv(
    "/public1/home/m6l600415/Public/dRep/retained_virus_metadata2.tsv",
    sep="\t", index=False
)
